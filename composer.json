{
    "name": "mozhuilungdsuo/laravel-cdac-e-hastakshar",
    "description": "Laravel package for CDAC e-Hastakshar PDF request and response handling.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-imagick": "*",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "robrichards/xmlseclibs": "^3.1",
        "tecnickcom/tc-font-mirror": "^2.1",
        "tecnickcom/tc-lib-pdf": "^8.38"
    },
    "require-dev": {
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mozhuilungdsuo\\LaravelCdacEHastakshar\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mozhuilungdsuo\\LaravelCdacEHastakshar\\EsignServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
